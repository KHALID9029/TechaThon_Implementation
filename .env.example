# Copy this file to .env and fill in real values. Never commit .env.
DISCORD_TOKEN=
ALERT_CHANNEL_ID=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
OFFICE_TZ=Asia/Dhaka
SIM_TICK_MS=5000
DB_PATH=./office.db

# Virtual clock (see docs/API_CONTRACT.md §2 and PROJECT_PLAN.md §5).
# Normal run: leave both at their defaults (real time, 1x speed).
# Demo run: e.g. SIM_START_TIME=2026-07-03T20:45:00 and SIM_TIME_SCALE=60
# so 1 real second = 1 virtual minute -- lets you cross into "after hours"
# and accumulate a 2-hour all-on window within a few real minutes.
SIM_START_TIME=
SIM_TIME_SCALE=1
